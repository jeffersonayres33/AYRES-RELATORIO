rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isSignedIn() && request.auth.token.email == 'jeffersonayresjefferson@gmail.com';
    }

    function isAdmin() {
      return isSuperAdmin() || 
        (isSignedIn() &&
         exists(/databases/$(database)/documents/authorized_users/$(request.auth.token.email)) &&
         get(/databases/$(database)/documents/authorized_users/$(request.auth.token.email)).data.role == 'admin');
    }

    function isAuthorizedUser() {
      return isSuperAdmin() || 
        (isSignedIn() &&
         exists(/databases/$(database)/documents/authorized_users/$(request.auth.token.email)));
    }

    function isValidAuthorizedEmail(data) {
      return data.keys().hasAll(['email', 'addedBy', 'createdAt', 'role']) && 
             data.keys().size() == 4 &&
             data.email is string && data.email.size() >= 3 && data.email.size() <= 100 &&
             data.addedBy is string && data.addedBy.size() >= 3 && data.addedBy.size() <= 100 &&
             data.createdAt is number &&
             data.role in ['admin', 'user'];
    }

    match /authorized_users/{emailId} {
      allow read: if isAdmin() || (isSignedIn() && request.auth.token.email == emailId);
      allow create: if isAdmin() && 
                    isValidAuthorizedEmail(request.resource.data) &&
                    request.resource.data.email == emailId &&
                    request.resource.data.addedBy == request.auth.token.email;
      allow update: if false; // Deleting and recreating is safer for simple access lists, or we can allow admins to update the role.
      allow delete: if isAdmin() && emailId != 'jeffersonayresjefferson@gmail.com';
    }
    match /evaluation_items/{itemId} {
      allow read: if isAuthorizedUser();
      allow write: if isAdmin();
    }
    match /evaluation_variables/{variableId} {
      allow read: if isAuthorizedUser();
      allow write: if isAdmin();
    }
    match /settings/{document=**} {
      allow read: if isAuthorizedUser();
      allow write: if isAdmin();
    }
    match /templateVariables/{variableId} {
      allow read: if isAuthorizedUser();
      allow write: if isAdmin();
    }
  }
}
